{
  "name": "@silmaril-security/sdk",
  "version": "0.4.2",
  "description": "TypeScript SDK for Silmaril Firewall — prompt injection and jailbreak detection",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Silmaril Security Inc.",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Silmaril-Security/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/Silmaril-Security/sdk-typescript/issues"
  },
  "homepage": "https://github.com/Silmaril-Security/sdk-typescript#readme",
  "keywords": [
    "silmaril",
    "firewall",
    "prompt-injection",
    "jailbreak",
    "llm-security",
    "ai-security",
    "langchain",
    "vercel-ai"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/vercel": {
      "import": {
        "types": "./dist/adapters/vercel.d.ts",
        "default": "./dist/adapters/vercel.js"
      },
      "require": {
        "types": "./dist/adapters/vercel.d.cts",
        "default": "./dist/adapters/vercel.cjs"
      }
    },
    "./adapters/langchain": {
      "import": {
        "types": "./dist/adapters/langchain.d.ts",
        "default": "./dist/adapters/langchain.js"
      },
      "require": {
        "types": "./dist/adapters/langchain.d.cts",
        "default": "./dist/adapters/langchain.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "ai": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@langchain/core": "^1.1.39",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "ai": "^6.0.191",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "undici": "^6.15.0",
    "vite": "6.4.2",
    "vitest": "3.2.4"
  }
}
